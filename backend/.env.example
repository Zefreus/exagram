# Database (MySQL External)
MONGO_URL="mongodb://localhost:27017"
DB_NAME="your_database"
DB_HOST="your_mysql_host"
DB_PORT="3306"
DB_USER="your_mysql_user"
DB_PASSWORD="your_mysql_password"
DB_MYSQL_NAME="your_mysql_database"

# CORS
CORS_ORIGINS=*

# AI API Keys (Fallback: Claude -> ChatGPT -> Emergent)
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_gemini_key
EMERGENT_LLM_KEY=your_emergent_key

# Mercado Pago
MP_ACCESS_TOKEN=your_mp_access_token
MP_PUBLIC_KEY=your_mp_public_key
MP_WEBHOOK_SECRET=your_mp_webhook_secret

# App Config
NEXTAUTH_SECRET=your_nextauth_secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
DPO_NAME="Your DPO Name"
DPO_EMAIL=dpo@example.com
RETENTION_DAYS=90
CONSENT_VERSION=1.0
CREDIT_EXPIRY_DAYS=365
